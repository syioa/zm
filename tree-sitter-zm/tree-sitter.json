{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "zm",
      "camelcase": "ZM",
      "title": "zm",
      "scope": "source.zm",
      "file-types": [
        "zm"
      ],
      "injection-regex": "^zm$",
      "class-name": "TreeSitterZm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "A parser for the zm markup language",
    "authors": [
      {
        "name": "syioa",
        "email": "lalitsingh.micro@gmail.com",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/syioa/zm",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": true
  }
}