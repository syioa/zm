{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "zm",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_block_content"
              },
              {
                "type": "REPEAT",
                "content": {
                  "type": "SYMBOL",
                  "name": "_inline_content"
                }
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "newline"
          }
        ]
      }
    },
    "_inline_content": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "bold"
        },
        {
          "type": "SYMBOL",
          "name": "italic"
        },
        {
          "type": "SYMBOL",
          "name": "link"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_normal_text"
          },
          "named": true,
          "value": "text"
        }
      ]
    },
    "_block_content": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "heading"
        },
        {
          "type": "SYMBOL",
          "name": "unordered_list"
        }
      ]
    },
    "text": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "don't use me"
      }
    },
    "attr": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "don't use me"
      }
    },
    "_normal_text": {
      "type": "TOKEN",
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "[^\\n\\\\\\#\\*\\_\\$\\-]+"
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "\\"
                },
                {
                  "type": "PATTERN",
                  "value": "."
                }
              ]
            }
          ]
        }
      }
    },
    "_link_text": {
      "type": "TOKEN",
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "[^\\n\\\\\\]]+"
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "\\"
                },
                {
                  "type": "PATTERN",
                  "value": "."
                }
              ]
            }
          ]
        }
      }
    },
    "url": {
      "type": "TOKEN",
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "[^\\s\\\\)]+"
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "\\"
                },
                {
                  "type": "PATTERN",
                  "value": "."
                }
              ]
            }
          ]
        }
      }
    },
    "bold": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "**"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "italic"
              },
              {
                "type": "SYMBOL",
                "name": "link"
              },
              {
                "type": "ALIAS",
                "content": {
                  "type": "SYMBOL",
                  "name": "_normal_text"
                },
                "named": true,
                "value": "text"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "**"
        }
      ]
    },
    "italic": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "__"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "bold"
              },
              {
                "type": "SYMBOL",
                "name": "link"
              },
              {
                "type": "ALIAS",
                "content": {
                  "type": "SYMBOL",
                  "name": "_normal_text"
                },
                "named": true,
                "value": "text"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "__"
        }
      ]
    },
    "link": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "$link"
        },
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_link_text"
          },
          "named": true,
          "value": "text"
        },
        {
          "type": "STRING",
          "value": "]("
        },
        {
          "type": "SYMBOL",
          "name": "url"
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "heading_marker": {
      "type": "PATTERN",
      "value": "#{1,6}"
    },
    "_heading_content": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "_inline_content"
      }
    },
    "heading": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "heading_marker"
        },
        {
          "type": "SYMBOL",
          "name": "_heading_content"
        }
      ]
    },
    "unordered_list": {
      "type": "SEQ",
      "members": [
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "unordered_list_item"
          }
        }
      ]
    },
    "unordered_list_item": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "ALIAS",
              "content": {
                "type": "TOKEN",
                "content": {
                  "type": "REPEAT",
                  "content": {
                    "type": "STRING",
                    "value": "  "
                  }
                }
              },
              "named": true,
              "value": "attr"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "PATTERN",
            "value": "\\-"
          }
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "PATTERN",
            "value": "\\ "
          }
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "_inline_content"
          }
        },
        {
          "type": "SYMBOL",
          "name": "newline"
        }
      ]
    },
    "newline": {
      "type": "STRING",
      "value": "\n"
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}